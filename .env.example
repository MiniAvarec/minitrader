# --- core ---
APP_ENV=dev
JWT_SECRET=change-me-to-a-long-random-string
MASTER_KEY=                     # Fernet key, generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# First user to register with this email is auto-promoted to admin and
# auto-approved. Every other registration is pending until the admin
# approves it from the /admin page in the UI.
ADMIN_EMAIL=

# --- db ---
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader
POSTGRES_DB=trader
DATABASE_URL=postgresql+asyncpg://trader:trader@postgres:5432/trader

# --- redis ---
# In production set REDIS_PASSWORD to a long random string and update
# REDIS_URL to redis://:${REDIS_PASSWORD}@redis:6379/0.
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# --- binance ---
BINANCE_USE_TESTNET=true
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT
BINANCE_TIMEFRAMES=1m,3m,15m,1h

# --- data feeds ---
FINNHUB_API_KEY=
CRYPTOPANIC_API_KEY=
# CryptoCompare (CCData) news — free w/ key, ~150 source aggregator.
# Sign up at https://www.cryptocompare.com/cryptopian/api-keys
CRYPTOCOMPARE_API_KEY=
# NewsData.io — free tier 200 credits/day. Polled on a slow cadence.
# Sign up at https://newsdata.io/register
NEWSDATA_API_KEY=
# Reddit hype scraper uses public JSON; Reddit requires a non-default UA.
# Replace the username portion with your own.
REDDIT_USER_AGENT=minitrader/0.1 (by /u/yourname)

# --- interactive brokers (optional) ---
# IB Gateway runs as a sidecar (docker compose --profile ibkr up).
# Paper trading uses port 4002, live uses 4001. The TWS_USERID is your IBKR
# login; TRADING_MODE=paper points to the paper account.
IB_USERID=
IB_PASSWORD=
IB_TRADING_MODE=paper
# clientId conventions (IBKR rejects duplicates on one gateway).
IBKR_CLIENT_ID_REST=4
IBKR_CLIENT_ID_INGESTOR=2
IBKR_CLIENT_ID_EXECUTOR=1
IBKR_CLIENT_ID_FILLSTREAM=3

# --- telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-to-another-random-string

# --- internal ---
WORKER_SHARED_SECRET=change-me-to-yet-another-random-string
FRONTEND_ORIGIN=http://localhost:5173
